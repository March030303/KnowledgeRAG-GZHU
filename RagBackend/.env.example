# ============================================
# 环境配置文件示例 (.env.example)
# 复制本文件为 .env 并根据实际环境填写配置
# ============================================

# 运行环境：development / testing / production
ENV_MODE=development

# ============ 知识库存储 ============
KB_STORAGE_PATH=./local-KLB-files
MAX_FILE_SIZE=52428800  # 50MB
CHUNK_SIZE=102400       # 100KB

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_DIR=./logs

# ============ 数据库配置 ============
# 本地后端 + Docker MySQL 开发时，推荐 DB_PORT=3307
# 完整 Docker 容器内互联场景保持 3306
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=rag_user_db
DB_CHARSET=utf8mb4

# ============ JWT 认证 ============
# ⚠️ 生产环境必须修改此值
# 推荐使用 JWT_SECRET；代码同时兼容旧名 JWT_SECRET_KEY
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24
# JWT_SECRET_KEY=your-secret-key-change-in-production
# JWT_EXPIRE_HOURS=24

# ============ Ollama / 默认模型 ============
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300
# 推荐使用 MODEL；代码同时兼容旧名 DEFAULT_LLM_MODEL
MODEL=qwen2:0.5b
# DEFAULT_LLM_MODEL=qwen2:0.5b

# ============ 向量 / 重排 / KG ============
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RERANK_MODEL=bge-large
KG_MODEL=qwen2:0.5b

# ============ Redis 配置（可选） ============
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ============ 知识库默认参数 ============
KB_DEFAULT_CHUNK_SIZE=1000
KB_DEFAULT_CHUNK_OVERLAP=200
KB_DEFAULT_SIMILARITY_THRESHOLD=0.7

# ============ CORS 配置 ============
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8089

# ============ 云端模型（可选） ============
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=sk-xxx
HUNYUAN_SECRET_ID=xxx
HUNYUAN_SECRET_KEY=xxx
DASHSCOPE_API_KEY=sk-xxx
XFYUN_APP_ID=xxx
XFYUN_API_KEY=xxx
XFYUN_API_SECRET=xxx

# ============ LangSmith（可选） ============
LANGSMITH_API_KEY=lsv2_xxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=knowledge-rag-gzhu
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============ 语音识别（可选） ============
WHISPER_MODEL=base

# ============ 飞书集成（可选） ============
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_ENCRYPT_KEY=xxx
FEISHU_DEFAULT_KB_ID=

# ============ QQ 登录（可选） ============
# 当前代码里仍有默认值，生产环境建议显式覆盖
QQ_APP_ID=your_qq_app_id
QQ_APP_KEY=your_qq_app_key
QQ_REDIRECT_URI=http://localhost:8000/api/qq/callback
FRONTEND_URL=http://localhost:5173

# ============ 邮件（可选） ============
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your_email@163.com
# SMTP_PASSWORD=your_smtp_password

# ============ 说明 ============
# 1) 钉钉 / 企微当前主要由设置页或请求体传入 webhook_url / secret，未固定读取 DINGTALK_* / WECOM_* 环境变量。
# 2) Notion / GitHub 当前为保存配置 + 测试占位接口，未固定读取 NOTION_* / GITHUB_* 启动环境变量。
# 3) OSS / S3 / MinIO / MySQL / PostgreSQL 数据源参数由多数据源接口提交，而不是固定写死在本文件。

