# ============================================
# 环境配置文件示例 (.env.example)
# 复制本文件为 .env 并根据环境填写配置
# ============================================

# 运行环境：development / testing / production
ENV_MODE=development

# ============ 知识库存储 ============
# 知识库本地存储路径（绝对路径或相对路径）
KB_STORAGE_PATH=./local-KLB-files

# 最大文件大小（字节）
MAX_FILE_SIZE=52428800  # 50MB

# 文件分块大小（字节）
CHUNK_SIZE=102400  # 100KB

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_DIR=./logs

# ============ 数据库配置 ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=rag_user_db

# ============ JWT 认证 ============
# ⚠️ 生产环境必须修改此值
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# ============ Ollama 配置 ============
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300
DEFAULT_LLM_MODEL=qwen2:0.5b

# ============ 向量模型 ============
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============ Redis 配置（可选） ============
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ============ 知识库默认参数 ============
KB_DEFAULT_CHUNK_SIZE=1000
KB_DEFAULT_CHUNK_OVERLAP=200
KB_DEFAULT_SIMILARITY_THRESHOLD=0.7

# ============ CORS 配置 ============
# 允许的跨域源，多个使用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8089
