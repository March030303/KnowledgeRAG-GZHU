{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KnowledgeRAG",
  "version": "1.0.0",
  "identifier": "com.knowledgeRAG.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "KnowledgeRAG 智能知识库",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:* https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      }
    },
    "shortDescription": "RAG 智能知识库系统",
    "longDescription": "基于 RAG 的智能知识库系统，支持文档上传、问答、搜索、文档创作等功能"
  }
}
